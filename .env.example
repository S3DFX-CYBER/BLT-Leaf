## .env.example - environment variables for BLT-Leaf
# Copy this file to .env (the setup script will do this and overwrite .env)
# Fill values or leave blank for defaults. Do NOT commit your real secrets.

# D1 database id
D1_DATABASE_ID=

# Shared GitHub token (optional fallback).
# Used when users are not logged in via OAuth.
GITHUB_TOKEN=

# Optional GitHub OAuth app settings (enable per-user tokens)
# Create OAuth app in GitHub Developer Settings and set callback to:
#   https://<your-worker-domain>/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optional scope override (default: "repo read:user")
GITHUB_OAUTH_SCOPE=

# Session encryption key for OAuth cookies.
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# Cloudflare account ID (optional, used by some workflows)
CLOUDFLARE_ACCOUNT_ID=

# Optional: API token for Wrangler authentication (preferred over WRANGLER_API_TOKEN)
CLOUDFLARE_API_TOKEN=

# Optional: legacy alias for CLOUDFLARE_API_TOKEN (deprecated, use CLOUDFLARE_API_TOKEN instead)
# WRANGLER_API_TOKEN=

# Slack incoming webhook URL for error notifications (frontend and backend)
# Create at https://api.slack.com/apps → Incoming Webhooks
SLACK_ERROR_WEBHOOK=
